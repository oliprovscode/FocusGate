<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <uses-feature android:name="android.hardware.camera.front" android:required="false" />
    <uses-feature android:name="android.hardware.sensor.stepcounter" android:required="false" />

    <application
        android:name=".FocusGateApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusGate">

        <!-- Main entry screen -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Task selection screen -->
        <activity
            android:name=".ui.TaskPickerActivity"
            android:exported="false" />

        <!-- Pushup camera task -->
        <activity
            android:name=".ui.tasks.PushupTaskActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Timed reading task -->
        <activity
            android:name=".ui.tasks.ReadingTaskActivity"
            android:exported="false" />

        <!-- Step counter task -->
        <activity
            android:name=".ui.tasks.StepsTaskActivity"
            android:exported="false" />

        <!-- Shower / hydration checkbox tasks -->
        <activity
            android:name=".ui.tasks.CheckboxTaskActivity"
            android:exported="false" />

        <!-- Accessibility service (app blocker) -->
        <service
            android:name=".service.FocusAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Block overlay activity (full screen, shown over Instagram) -->
        <activity
            android:name=".ui.BlockedActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:theme="@style/Theme.FocusGate.Fullscreen" />

        <!-- Boot receiver -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
