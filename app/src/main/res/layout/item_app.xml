<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/space_4"
    android:paddingEnd="@dimen/space_4"
    android:paddingTop="@dimen/space_3"
    android:paddingBottom="@dimen/space_3"
    android:background="?attr/selectableItemBackground">

    <!-- App icon -->
    <ImageView
        android:id="@+id/ivAppIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="@dimen/space_4"
        android:scaleType="fitCenter" />

    <!-- Labels -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAppLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_base"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvAppPackage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_faint"
            android:textSize="@dimen/text_xs"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Block toggle -->
    <Switch
        android:id="@+id/switchBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_4" />

</LinearLayout>
