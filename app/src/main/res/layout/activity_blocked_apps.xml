<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_4"
        android:paddingTop="@dimen/space_8">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Blocked Apps"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/space_2" />

    </LinearLayout>

    <!-- Subtle divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:alpha="0.4" />

    <!-- Search bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_4">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_card"
            android:hint="Search apps"
            android:textColorHint="@color/text_faint"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_base"
            android:paddingStart="@dimen/space_4"
            android:paddingEnd="@dimen/space_4"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

    </FrameLayout>

    <!-- Caption -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blocked apps require a task before opening"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_xs"
        android:letterSpacing="0.04"
        android:paddingStart="@dimen/space_4"
        android:paddingEnd="@dimen/space_4"
        android:paddingBottom="@dimen/space_3" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- App list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_8" />

</LinearLayout>
