<resources>
    <string name="app_name">FocusGate</string>
    <string name="accessibility_service_label">FocusGate App Blocker</string>
    <string name="accessibility_service_description">FocusGate monitors when blocked apps are opened and shows a task gate instead.</string>

    <!-- Tasks -->
    <string name="task_pushups_title">10 Pushups</string>
    <string name="task_pushups_desc">Put the phone down and do 10 pushups. Front camera tracks your reps.</string>
    <string name="task_shower_title">Morning Shower</string>
    <string name="task_shower_desc">Available 08:00–10:00. Confirm you took a shower.</string>
    <string name="task_steps_title">250 Steps</string>
    <string name="task_steps_desc">Walk 250 steps away from your screen.</string>
    <string name="task_read_title">Read for 5 Minutes</string>
    <string name="task_read_desc">Put the phone down and read a physical book for 5 minutes.</string>
    <string name="task_water_title">Drink a Full Glass of Water</string>
    <string name="task_water_desc">Get up, drink a full glass of water, and confirm.</string>
    <string name="task_breathing_title">Box Breathing (4 Cycles)</string>
    <string name="task_breathing_desc">Inhale 4s, hold 4s, exhale 4s, hold 4s. Repeat 4 times.</string>

    <!-- UI -->
    <string name="blocked_title">Not yet.</string>
